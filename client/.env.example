# 你的 Cloudflare Worker 地址
# 本地调试：http://localhost:8787
# 线上部署：https://meem.<your-subdomain>.workers.dev

MEEM_URL=

# 可选：会话访问密码。设置后，网页端连接后需要先输入密码
SESSION_PASSWORD=

# 可选：浏览器控制
# 默认尝试使用本机 Chrome，可按需改成 chromium / msedge 等
BROWSER_CHANNEL=chrome

# Agent 模型配置（API URL / Key / Model）在 web 端"设置"里填写，
# 持久化到 ~/.meem/meem.db 的 settings 表。
