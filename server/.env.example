# Cloudflare Worker URL
# Local dev: http://localhost:8787
# Production: https://meem.<your-subdomain>.workers.dev

MEEM_URL=

# Optional session access password
SESSION_PASSWORD=

# Browser channel for Playwright-controlled browser automation
BROWSER_CHANNEL=chrome

# Local bridge for the Chrome extension
CHROME_EXTENSION_HOST=127.0.0.1
CHROME_EXTENSION_PORT=17373

# Agent model settings are configured in the web UI and stored in ~/.meem/meem.db
